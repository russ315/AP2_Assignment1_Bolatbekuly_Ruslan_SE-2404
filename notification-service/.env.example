# PostgreSQL (notification_db — processed event ids)
NOTIFICATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/notification_db?sslmode=disable

# RabbitMQ consumer
NOTIFICATION_RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Optional: messages whose JSON order_id equals this value are Nacked without requeue (DLQ demo).
# NOTIFICATION_DLQ_DEMO_ORDER_ID=__demo_dlq_order__
