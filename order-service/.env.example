# Order Service Environment Configuration

# Database connection
ORDER_DATABASE_URL=postgres://user:password@localhost:5432/order_db?sslmode=disable

# Payment service gRPC address
PAYMENT_GRPC_ADDR=localhost:50051

# Order service gRPC streaming address
ORDER_GRPC_ADDR=:50052

# HTTP server address (for REST API)
ORDER_HTTP_ADDR=:8080

# Required on POST /orders JSON: customer_email (sent to Payment for notification events).
