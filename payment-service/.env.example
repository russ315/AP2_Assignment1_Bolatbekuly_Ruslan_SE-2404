# Payment Service Environment Configuration

# Database connection
PAYMENT_DATABASE_URL=postgres://user:password@localhost:5432/payment_db?sslmode=disable

# gRPC server address
PAYMENT_GRPC_ADDR=:50051

# HTTP server address (for REST API)
PAYMENT_HTTP_ADDR=:8081

# RabbitMQ (publish payment.completed after Authorized commit). Omit for local runs without broker.
PAYMENT_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
